---
import BaseLayout from '../layouts/BaseLayout.astro';
import Kicker from '../components/Kicker.astro';
import Button from '../components/Button.astro';
import SectionHead from '../components/SectionHead.astro';
import FeatureCard from '../components/FeatureCard.astro';
import Quote from '../components/Quote.astro';
import { voices } from '../data/voices';
import '../styles/home.css';
---

<BaseLayout title="Migraine Aura Foundation — Make your migraine visible" active="">
  <!-- HERO -->
  <section class="hero section">
    <div class="wrap hero__grid">
      <div class="hero__copy">
        <Kicker>A foundation built from patient voices</Kicker>
        <h1 class="hero__title">Make your migraine <em>visible</em>.</h1>
        <p class="hero__sub">
          Migraine aura often begins where words fail — in flickering light, numbness, lost speech,
          distorted time. We translate that experience into the formal language of diagnosis, so you
          can be understood.
        </p>
        <div class="hero__cta">
          <Button href="/aura-check" variant="primary" size="lg" arrow>Take the 10-minute aura check</Button>
          <Button href="/field-guide" variant="ghost" size="lg">Browse the Field Guide</Button>
        </div>
        <p class="hero__micro">Turn your symptoms into a clear report you can share with your doctor.</p>
      </div>
      <figure class="hero__art">
        <img src="/img/art-fortification.png" alt="Patient artwork: a scintillating zigzag cutting across a skyline — a visual aura." />
        <figcaption>“Fortification spectrum” over Rotes Rathaus — patient artwork depicting a visual aura.</figcaption>
      </figure>
    </div>
  </section>

  <!-- STATS -->
  <section class="band section--tight">
    <div class="wrap introstats">
      <p class="introstats__lead">
        For over 25 years we have listened, gathered, and named what migraine does — building
        <strong>one of the world's most comprehensive records of aura.</strong>
      </p>
      <dl class="stats">
        <div class="stat"><dt class="stat__n">7,000<span class="stat__plus">+</span></dt><dd class="stat__l">First-hand accounts of aura collected from patients</dd></div>
        <div class="stat"><dt class="stat__n">1998</dt><dd class="stat__l">Gathering and naming aura symptoms since</dd></div>
        <div class="stat"><dt class="stat__n">40<span class="stat__plus">+</span></dt><dd class="stat__l">Distinct aura symptoms documented in the Field Guide</dd></div>
      </dl>
    </div>
  </section>

  <!-- FEATURES -->
  <section class="section">
    <div class="wrap">
      <SectionHead kicker="Explore" title="Four ways in" sub="Whether you are trying to name what you feel, prepare for an appointment, or understand a loved one's experience — start here." />
      <div class="features">
        <FeatureCard title="A Field Guide to Symptoms" sub="Browse a complete catalogue of migraine aura symptoms — transitory and persistent — in plain language." href="/field-guide" linkLabel="Open the guide">
          <svg slot="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M4 5.5A2 2 0 0 1 6 4h6v15H6a2 2 0 0 0-2 2V5.5Z"/><path d="M20 5.5A2 2 0 0 0 18 4h-6v15h6a2 2 0 0 1 2 2V5.5Z"/></svg>
        </FeatureCard>
        <FeatureCard title="Revealing Experiences" sub="Art and stories that make migraine's hidden impact visible — to families, clinicians, and yourself." href="/experiences" linkLabel="See the gallery" warm>
          <svg slot="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><rect x="3.5" y="4.5" width="17" height="15" rx="2"/><path d="M3.5 16l4.2-4 3.3 3 3.2-3.6 6.3 5.1"/><circle cx="8.5" cy="9" r="1.5"/></svg>
        </FeatureCard>
        <FeatureCard title="The Aura Check" sub="A guided 10-minute anamnesis that turns what you experience into a structured report for your doctor." href="/aura-check" linkLabel="Start the check">
          <svg slot="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12h3.5l2-6 4 13 2.5-7H21"/></svg>
        </FeatureCard>
        <FeatureCard title="Next-gen Migraine Care" sub="Evidence-based tools and research for clinicians and partners building what comes next." href="/next-gen-migraine-care" linkLabel="For professionals" warm>
          <svg slot="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3v6M12 9a4 4 0 0 0-4 4v1a4 4 0 0 0 8 0v-1a4 4 0 0 0-4-4Z"/><circle cx="12" cy="20" r="1.6"/></svg>
        </FeatureCard>
      </div>
    </div>
  </section>

  <!-- EXPERIENCES -->
  <section class="section band">
    <div class="wrap">
      <div class="exp">
        <div class="exp__copy">
          <Kicker>Revealing experiences</Kicker>
          <h2 class="exp__title">When words fail, people paint.</h2>
          <p class="exp__text">Since the 1990s, patients have sent us paintings, drawings, and writing that capture what aura feels like from the inside. Together they form a living archive — proof that these symptoms are real, shared, and nameable.</p>
          <Button href="/experiences" variant="ghost" arrow>Explore the archive</Button>
        </div>
        <div class="exp__gallery">
          <figure class="exp__fig exp__fig--tall"><img src="/img/art-genetics.jpg" alt="Patient painting of a dark bauble labelled Migraine held between hands." /></figure>
          <figure class="exp__fig"><img src="/img/art-mosaic.jpg" alt="Mosaic-like fragmentation of vision during aura." /></figure>
          <figure class="exp__fig"><img src="/img/art-toast.png" alt="Patient artwork exploring pareidolia." /></figure>
        </div>
      </div>
    </div>
  </section>

  <!-- VOICES -->
  <section class="section">
    <div class="wrap">
      <SectionHead kicker="In their words" title="It makes you feel less alone" center />
      <div class="voices">
        {voices.map((v) => <Quote author={v.author} feature={v.feature}>{v.text}</Quote>)}
      </div>
    </div>
  </section>

  <!-- HCP BAND -->
  <section class="section">
    <div class="wrap">
      <div class="hcp">
        <div class="hcp__text">
          <span class="kicker" style="color:var(--warm-soft);--warm:var(--on-primary)">For healthcare professionals</span>
          <h2 class="hcp__title">Co-create next-generation migraine care.</h2>
          <p class="hcp__sub">We equip clinicians and industry partners with evidence-based tools, research, and patient-derived data for every stage of migraine care — from first aura to long-term management.</p>
          <a class="btn hcp__cta" href="/next-gen-migraine-care">Collaborate with us <span class="arr">→</span></a>
        </div>
        <div class="hcp__panel" aria-hidden="true">
          <div class="hcp__stat"><span class="hcp__stat-n">ICHD-3</span><span class="hcp__stat-l">Aligned to diagnostic criteria</span></div>
          <div class="hcp__stat"><span class="hcp__stat-n">Open</span><span class="hcp__stat-l">Patient-derived symptom data</span></div>
          <div class="hcp__stat"><span class="hcp__stat-n">25 yrs</span><span class="hcp__stat-l">Longitudinal patient voices</span></div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
