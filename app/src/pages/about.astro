---
import BaseLayout from '../layouts/BaseLayout.astro';
import Kicker from '../components/Kicker.astro';
import SectionHead from '../components/SectionHead.astro';
import TimelineItem from '../components/TimelineItem.astro';
import CtaBand from '../components/CtaBand.astro';
import '../styles/pages.css';

const values = [
  { n: '01', title: 'Patient-centered', text: 'The individual experience is our starting point.' },
  { n: '02', title: 'Science-based', text: 'Research is the foundation of our actions.' },
  { n: '03', title: 'Translational', text: 'Translating insights directly into healthcare.' },
  { n: '04', title: 'Digitally competent', text: 'Using technology effectively for patients.' },
];
const founders = [
  { initials: 'MD', name: 'Markus A. Dahlem, PhD', role: 'Theoretical physicist · aura modelling & digital health' },
  { initials: 'KP', name: 'Dr. med. Klaus Podoll', role: 'Neurologist · Migraine Art archive (1958–2019)' },
];
const timeline = [
  { date: '1998', title: 'First online presence', text: "The first scientifically grounded simulation of the migraine aura — developed during Markus Dahlem's PhD in theoretical physics — is published online, making the invisible aura visible to others." },
  { date: 'March 2000', title: 'Encouragement from Oliver Sacks', text: "A personal letter from the neurologist and bestselling author acknowledges the work's significance. His patient-centered approach becomes a guiding principle." },
  { date: '2003', title: 'The Migraine Art platform expands', text: "A collaboration with Dr. Klaus Podoll brings an extensive archive — building on Derek Robinson's pioneering work from 1973 — into one of the world's most significant digital collections of lived aura experiences." },
  { date: '2004', title: 'The Foundation is founded', text: 'With a growing network, guestbook, and the Migraine Art section, the Migraine Aura Foundation is officially established — following a dual path of nonprofit education and translational research.' },
  { date: '2009', title: 'A book and a blog', text: 'Migraine Art: The Migraine Experience from Within is published, and the science blog Graue Substanz launches — eventually home to more than 400 posts on migraine physiology.' },
  { date: '2011', title: 'Literary recognition', text: "In The Shaking Woman, Siri Hustvedt describes how the aura experiences on the foundation's website opened new perspectives on neurological experience." },
  { date: '2019', title: 'Loss of a pioneer', text: "The passing of Dr. Klaus Podoll leaves a significant void — a long-time contributor who shaped the platform's content, network, and scientific depth." },
  { date: '2025', title: 'Website relaunch', text: 'A complete relaunch brings a new design, the return of the blog, and the Aura-o-mat — more modern, interactive, and integrated than ever.' },
];
---

<BaseLayout title="About us — Migraine Aura Foundation">
  <section class="section">
    <div class="wrap">
      <div class="mission">
        <Kicker variant="blue" center>Our mission</Kicker>
        <p class="mission__statement" style="margin-top:20px">Making migraine <em>visible</em> — and clinically meaningful.</p>
      </div>
      <p class="lead center mx-auto" style="max-width:60ch; margin-top:32px;">Migraine affects nearly one billion people worldwide. We place the lived experience of those affected at the center of our work — connecting subjective experience with objective modelling, and developing digital tools that improve communication, diagnosis, and treatment.</p>
    </div>
  </section>

  <section class="section--tight band">
    <div class="wrap">
      <SectionHead kicker="What grounds us" kickerVariant="warm" title="Four core values" />
      <div class="values">
        {values.map((v) => (
          <div class="value"><div class="value__n">{v.n}</div><h3 class="value__title">{v.title}</h3><p class="value__text">{v.text}</p></div>
        ))}
      </div>
    </div>
  </section>

  <section class="section--tight">
    <div class="wrap">
      <SectionHead kicker="Our founders" kickerVariant="warm" title="Who started this" />
      <div class="founders">
        {founders.map((f) => (
          <div class="founder"><div class="founder__avatar">{f.initials}</div><div><div class="founder__name">{f.name}</div><div class="founder__role">{f.role}</div></div></div>
        ))}
      </div>
    </div>
  </section>

  <section class="section--tight band">
    <div class="wrap">
      <SectionHead kicker="Our history" title="From a simulation to a foundation" sub="A 25-year arc of making the invisible visible — through science, art, and the patient voice." />
      <div class="timeline">
        {timeline.map((t) => <TimelineItem date={t.date} title={t.title}>{t.text}</TimelineItem>)}
      </div>
    </div>
  </section>

  <section class="section--tight">
    <div class="wrap">
      <CtaBand
        title="Be part of what comes next"
        text="From living with migraine to helping shape future care — share your experience, or collaborate with us on research and digital tools."
        ctaLabel="Get in touch"
        ctaHref="/contact"
      />
    </div>
  </section>
</BaseLayout>
