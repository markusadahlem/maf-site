---
import { getCollection } from 'astro:content';
import BlogArticle from '../../../components/BlogArticle.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog', (e) => e.slug.startsWith('de/'));
  return posts.map((post) => ({ params: { slug: post.slug.replace(/^de\//, '') }, props: { post } }));
}

const { post } = Astro.props;
---
<BlogArticle post={post} locale="de" />
