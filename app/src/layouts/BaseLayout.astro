---
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import Analytics from '../components/Analytics.astro';
import { site } from '../config/site';
import '../styles/theme.css';

interface Props {
  title: string;
  description?: string;
  /** nav key to highlight */
  active?: string;
  showFooter?: boolean;
  /** page locale — drives <html lang>, read client-side by the engine */
  lang?: string;
}
const { title, description = site.description, active, showFooter = true, lang = 'en' } = Astro.props;

// Language switcher target: the same path under the other locale (en at root,
// de under /de). Pages without a twin in the other locale are a known gap.
const path = Astro.url.pathname;
const altLang = lang === 'de' ? 'en' : 'de';
const altUrl = lang === 'de' ? path.replace(/^\/de(?=\/|$)/, '') || '/' : `/de${path}`;

// Canonical + hreflang alternates, resolved against the apex `site`.
const canonical = new URL(path, Astro.site).href;
const altCanonical = new URL(altUrl, Astro.site).href;
---

<!doctype html>
<html lang={lang} data-theme="light">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>

    <link rel="canonical" href={canonical} />
    <link rel="alternate" hreflang={lang} href={canonical} />
    <link rel="alternate" hreflang={altLang} href={altCanonical} />

    <link rel="icon" href="/favicon.ico" sizes="32x32" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" media="(prefers-color-scheme: light)" />
    <link rel="icon" href="/favicon-dark.svg" type="image/svg+xml" media="(prefers-color-scheme: dark)" />
    <link rel="apple-touch-icon" href="/favicon-180x180.png" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Hanken+Grotesk:wght@400;500;600;700&family=Source+Serif+4:ital,opsz,wght@0,8..60,400;0,8..60,500;0,8..60,600;1,8..60,400&display=swap"
      rel="stylesheet"
    />

    {/* No-flash theme init — must run before paint */}
    <script is:inline>
      (function () {
        var t = localStorage.getItem('maf-theme');
        if (!t) t = matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
        document.documentElement.setAttribute('data-theme', t);
      })();
    </script>

    <Analytics />
    <slot name="head" />
  </head>
  <body>
    <Nav active={active} altUrl={altUrl} altLang={altLang} />
    <main>
      <slot />
    </main>
    {showFooter && <Footer />}
  </body>
</html>
