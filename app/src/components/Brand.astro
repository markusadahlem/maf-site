---
// The aura mark: a scintillating-scotoma zigzag inside a ring.
// `withText` renders the full lockup (name + optional tagline).
interface Props {
  href?: string;
  withText?: boolean;
  showTagline?: boolean;
}
import { site } from '../config/site';
const { href = '/', withText = true, showTagline = false } = Astro.props;
---

<a class="brand" href={href} aria-label={`${site.name} — home`}>
  <span class="brand__mark" aria-hidden="true">
    <svg viewBox="0 0 40 40" fill="none">
      <circle cx="20" cy="20" r="18" stroke="currentColor" stroke-width="1.6" opacity="0.32" />
      <path
        d="M9 20 L13 14 L16 23 L20 11 L24 26 L27 16 L31 20"
        stroke="var(--primary)"
        stroke-width="2.2"
        stroke-linejoin="round"
        stroke-linecap="round"
      />
    </svg>
  </span>
  {
    withText && (
      <span class="brand__text">
        <span class="brand__name">{site.name}</span>
        {showTagline && <span class="brand__sub">{site.tagline}</span>}
      </span>
    )
  }
</a>
