---
// ExperienceSection — the lived-experience lead-in to Migraine Art: the
// "expressed in art → into clinical language" two-track + curated patient-art
// gallery + CTA. Rendered inline at the top of the /art landing (was the
// standalone /experiences page). Locale-driven; the artwork is shared.
import SectionHead from '../components/SectionHead.astro';
import Track from '../components/Track.astro';
import GalleryFigure from '../components/GalleryFigure.astro';
import CtaBand from '../components/CtaBand.astro';
import '../styles/pages.css';

interface Props { locale: string }
const { locale } = Astro.props;
const isDe = locale === 'de';
const p = (path: string) => (isDe ? `/de${path}` : path);

const gallery = [
  { img: '/img/art-genetics.jpg', alt: 'Painting of a dark bauble labelled Migraine held between hands.', en: { title: 'The Migraine', caption: 'Migraine passed between generations — patient painting.' }, de: { title: 'Die Migräne', caption: 'Über Generationen weitergegebene Migräne — Patientengemälde.' } },
  { img: '/img/art-mosaic.jpg', alt: 'Mosaic-like fragmentation of vision.', en: { title: 'Mosaic vision', caption: 'The visual field fractured into tiles during aura.' }, de: { title: 'Mosaiksehen', caption: 'Das Gesichtsfeld zersplittert während der Aura in Kacheln.' } },
  { img: '/img/art-corona.jpg', alt: 'Corona phenomenon artwork.', en: { title: 'Corona phenomenon', caption: 'Halos and coronas around points of light.' }, de: { title: 'Korona-Phänomen', caption: 'Höfe und Koronen um Lichtpunkte.' } },
  { img: '/img/art-dugan.jpg', alt: 'Patrick Dugan — The Migraine.', en: { title: 'The Migraine — P. Dugan', caption: "An artist's depiction of an attack." }, de: { title: 'Die Migräne — P. Dugan', caption: 'Die Darstellung einer Attacke durch einen Künstler.' } },
  { img: '/img/art-greene.jpg', alt: 'Sofia Greene — afterimage of a ship.', en: { title: 'Afterimage — S. Greene', caption: 'Visual perseveration: an image that lingers.' }, de: { title: 'Nachbild — S. Greene', caption: 'Visuelle Perseveration: ein Bild, das nachklingt.' } },
  { img: '/img/art-alice.png', alt: 'Body-size distortion — Alice in Wonderland syndrome.', en: { title: 'Alice in Wonderland', caption: 'Body-image and size distortions during aura.' }, de: { title: 'Alice im Wunderland', caption: 'Körperbild- und Größenverzerrungen während der Aura.' } },
  { img: '/img/art-heaton.jpg', alt: 'Roger Heaton — Migraine Images, 1992.', en: { title: 'Migraine Images — R. Heaton', caption: 'A series exploring the aura, 1992.' }, de: { title: 'Migräne-Bilder — R. Heaton', caption: 'Eine Serie über die Aura, 1992.' } },
  { img: '/img/art-diggiemoon.jpg', alt: 'Diggiemoon migraine artwork.', en: { title: 'Untitled — Diggiemoon', caption: 'A contemporary rendering of visual disturbance.' }, de: { title: 'Ohne Titel — Diggiemoon', caption: 'Eine zeitgenössische Darstellung visueller Störung.' } },
  { img: '/img/art-robinson.jpg', alt: 'Derek Robinson, 1984.', en: { title: 'Early work — D. Robinson', caption: 'From the pioneering archive begun in 1973.' }, de: { title: 'Frühes Werk — D. Robinson', caption: 'Aus dem 1973 begonnenen Pionierarchiv.' } },
];

const UI = isDe
  ? {
      kicker: 'Erfahrung',
      title: 'Das Unsichtbare sichtbar machen',
      lead: 'Aura ist real — und wie du sie beschreibst, ist wichtig. Ob in der Kunst ausgedrückt oder durch klinische Kriterien strukturiert: Jede Perspektive hilft, das Unsichtbare sichtbarer zu machen.',
      t1Tag: 'In der Kunst ausgedrückt', t1Title: 'Von innen', t1Link: 'Das Archiv durchstöbern',
      t1Body: "Diese digital bearbeitete Fotografie wurde von einer Person mit Migräne erstellt, um zu zeigen, wie sie eine visuelle Aura erlebte. Migränekunst erfasst, was Worte oft nicht können — unser Archiv umfasst über fünf Jahrzehnte.",
      t2Tag: 'Durch medizinische Kriterien strukturiert', t2Title: 'In die klinische Sprache', t2Link: 'Den Symptom-Leitfaden erkunden',
      t2Body: 'Unsere Symptomkarte übersetzt Erfahrung in klinische Begriffe — basierend auf <strong>ICHD-3</strong> und abgestimmt auf die kommende ICHD-4-Beta. Positive und negative Merkmale sind nur eines von sechs Kriterien zur Diagnose der Aura.',
      shKicker: 'Das Migränekunst-Archiv', shTitle: 'Fünf Jahrzehnte Aura sehen',
      shSub: 'Eine Auswahl aus einer seit den 1970er-Jahren mit Patienten aufgebauten Sammlung — jedes Werk ein Versuch, eine Erfahrung wiederzugeben, die sich der Beschreibung entzieht.',
      aside: 'Über 7.000 individuelle Patientenberichte aus der ursprünglichen Version dieser Website werden sorgfältig für die erneute Veröffentlichung aufbereitet — eine laufende Anstrengung, die Sponsoren beschleunigen könnten.',
      asideLink: 'Nimm Kontakt auf.',
      ctaTitle: 'Von der Erfahrung zum Bericht',
      ctaText: 'Nachdem du gesehen hast, wie andere ihre Symptome ausdrücken — und wie die Medizin sie strukturiert — erstelle deinen eigenen Bericht: eine Zusammenfassung, die du verstehst und mit deiner Ärztin oder deinem Arzt teilen kannst.',
      ctaLabel: 'Aura-Check ausprobieren',
    }
  : {
      kicker: 'Experience',
      title: 'Making the invisible visible',
      lead: 'Aura is real — and how you describe it matters. Whether expressed in art or structured by clinical criteria, every perspective helps make the invisible more visible.',
      t1Tag: 'Expressed in art', t1Title: 'From the inside', t1Link: 'Browse the archive',
      t1Body: "This digitally altered photograph was created by a person with migraine to show how she experienced a visual aura. Migraine art captures what words often can't — our archive spans over five decades.",
      t2Tag: 'Structured by medical criteria', t2Title: 'Into clinical language', t2Link: 'Explore the Field Guide',
      t2Body: 'Our symptom map translates experience into clinical terms — based on <strong>ICHD-3</strong> and aligned with the upcoming ICHD-4 beta. Positive and negative features are just one of six criteria for diagnosing aura.',
      shKicker: 'The Migraine Art Archive', shTitle: 'Five decades of seeing aura',
      shSub: 'A selection from a collection built with patients since the 1970s — each piece an attempt to render an experience that resists description.',
      aside: 'Over 7,000 individual patient reports from the original version of this site are being carefully curated for re-publication here — an ongoing effort sponsors could help us accelerate.',
      asideLink: 'Get in touch.',
      ctaTitle: 'From experience to report',
      ctaText: "Now that you've seen how others express their symptoms — and how medicine structures them — create your own report: a summary you can understand and share with your doctor.",
      ctaLabel: 'Try the Aura Check',
    };
---

<section class="section--tight">
  <div class="wrap">
    <SectionHead kicker={UI.kicker} title={UI.title} sub={UI.lead} />
    <div class="two-track" style="margin-top:8px;">
      <Track img="/img/art-fortification.png" alt="Visual aura as a zigzag over a city skyline." tag={UI.t1Tag} title={UI.t1Title} href="#gallery" linkLabel={UI.t1Link}>
        <Fragment set:html={UI.t1Body} />
      </Track>
      <Track img="/img/art-clinical-criteria.png" alt="The same aura annotated with clinical diagnostic criteria." tag={UI.t2Tag} tagBlue title={UI.t2Title} href={p('/field-guide')} linkLabel={UI.t2Link}>
        <Fragment set:html={UI.t2Body} />
      </Track>
    </div>
  </div>
</section>

<section class="section--tight" id="gallery">
  <div class="wrap">
    <SectionHead kicker={UI.shKicker} title={UI.shTitle} sub={UI.shSub} />
    <div class="gallery">
      {gallery.map((g) => <GalleryFigure img={g.img} alt={g.alt} title={(isDe ? g.de : g.en).title} caption={(isDe ? g.de : g.en).caption} />)}
    </div>
    <aside style="margin-top:32px; padding-top:18px; border-top:1px solid var(--border); font-size:14.5px; color:var(--muted); max-width:70ch;">
      {UI.aside} <a href={p('/contact')}>{UI.asideLink}</a>
    </aside>
  </div>
</section>

<section class="section--tight">
  <div class="wrap">
    <CtaBand title={UI.ctaTitle} text={UI.ctaText} ctaLabel={UI.ctaLabel} ctaHref={p('/aura-check')} />
  </div>
</section>
