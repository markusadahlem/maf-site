---
// Blog index (featured + grid), generated from the `blog` collection, shared
// by the en and de routes.
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Kicker from '../components/Kicker.astro';
import Button from '../components/Button.astro';
import Tag from '../components/Tag.astro';
import PostCard from '../components/PostCard.astro';
import '../styles/pages.css';

interface Props { locale: string }
const { locale } = Astro.props;
const isDe = locale === 'de';

const UI = isDe
  ? { kicker: 'Wissenschaftsblog', title: 'Graue Substanz', lead: 'Überarbeitete Ausgaben ausgewählter Beiträge aus den Wissenschaftsblogs <em>Gray Matters</em> und <em>Graue Substanz</em> — aktualisiert für Klarheit und den heutigen Kontext.', read: 'Artikel lesen' }
  : { kicker: 'Science blog', title: 'Gray Matters', lead: "Revised editions of selected posts originally published on the science blogs <em>Gray Matters</em> and <em>Graue Substanz</em> — updated for clarity and today's context.", read: 'Read article' };

const hrefBase = isDe ? '/de/blog/' : '/blog/';
const locForDate = isDe ? 'de-DE' : 'en-GB';
const fmt = (d: Date) => d.toLocaleDateString(locForDate, { day: '2-digit', month: 'short', year: 'numeric' });
const tagVariant = (t: string): 'blue' | 'warm' | 'plain' => (['Neuroscience', 'Culture'].includes(t) ? 'warm' : 'blue');

const posts = (await getCollection('blog', (e) => (isDe ? e.slug.startsWith('de/') : !e.slug.startsWith('de/')))).sort(
  (a, b) => +b.data.date - +a.data.date,
);
const href = (slug: string) => hrefBase + slug.replace(/^de\//, '');
const [featured, ...rest] = posts;
---

<BaseLayout title={`${UI.title} — Migraine Aura Foundation`} lang={locale} active="blog">
  <div class="page-head">
    <div class="wrap">
      <Kicker>{UI.kicker}</Kicker>
      <h1 class="page-head__title">{UI.title}</h1>
      <p class="page-head__lead" set:html={UI.lead} />
    </div>
  </div>

  <div class="wrap section--tight">
    {
      featured && (
        <article class="post-featured">
          <div class="post-featured__media"><img src="/img/aura-o-mat.png" alt="" /></div>
          <div>
            <div class="post-meta">
              <Tag variant={tagVariant(featured.data.tag)}>{featured.data.tag}</Tag>
              <span class="dot" /><span>{fmt(featured.data.date)}</span>
              <span class="dot" /><span>{featured.data.author}</span>
            </div>
            <h2 class="post-featured__title"><a href={href(featured.slug)}>{featured.data.title}</a></h2>
            <p class="post-featured__excerpt">{featured.data.description}</p>
            <div style="margin-top:20px"><Button href={href(featured.slug)} variant="ghost" arrow>{UI.read}</Button></div>
          </div>
        </article>
      )
    }

    <div class="posts">
      {
        rest.map((p) => (
          <PostCard
            title={p.data.title}
            href={href(p.slug)}
            excerpt={p.data.description ?? ''}
            tag={p.data.tag}
            tagVariant={tagVariant(p.data.tag)}
            date={fmt(p.data.date)}
            author={p.data.author}
          />
        ))
      }
    </div>
  </div>
</BaseLayout>
