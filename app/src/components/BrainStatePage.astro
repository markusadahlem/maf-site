---
// "Explore Your Brain State" ‚ÄĒ the test-suit landing that embeds the pareidolia
// test (one MigraineBrainRadar dimension). Locale-driven; shared by en + de.
import BaseLayout from '../layouts/BaseLayout.astro';
import Kicker from '../components/Kicker.astro';
import PareidoliaTest from '../components/PareidoliaTest.astro';
import '../styles/guide.css';

interface Props { locale: string }
const { locale } = Astro.props;
const isDe = locale === 'de';
const mbrHref = isDe ? '/de/test-suit/migrainebrainradar' : '/test-suit/migrainebrainradar';

const T = isDe
  ? {
      title: 'Erkunde den Zustand deines Gehirns',
      lead: 'Ein neuer Blick auf das Migr√§ne-Gehirn',
      intro: 'Wie leicht dein Gehirn in Zuf√§lligem Muster erkennt, h√§ngt davon ab, wie empfindlich es gerade auf Reize reagiert, und diese Empfindlichkeit verschiebt sich vor, nach und zwischen Migr√§neattacken. Dies ist eine von sieben Dimensionen des MigraineBrainRadar‚ĄĘ ‚Äď jede muss ein solider, vollwertiger Test sein, und diese Dimension ist noch ein fr√ľher Prototyp.',
      outro: 'Was du gerade erlebt hast, nennt man <strong>Pareidolie</strong> ‚Äď dein Gehirn macht aus Rauschen Bedeutung. Unser Ziel ist es, diese kleinen Verschiebungen sichtbar zu machen, die in klassischen Checklisten oft fehlen.',
      link: 'Zum MigraineBrainRadar‚ĄĘ ‚Üí',
    }
  : {
      title: 'Explore Your Brain State',
      lead: 'A new way to understand the migraine brain',
      intro: 'How easily your brain finds patterns in randomness depends on how sensitive it currently is to stimulation, and that sensitivity shifts before, after and between migraine attacks. This is one of seven dimensions in the MigraineBrainRadar‚ĄĘ ‚ÄĒ each needs to be a solid, proper test, and this dimension is still an early prototype.',
      outro: 'What you just experienced is pareidolia ‚ÄĒ your brain making meaning out of noise. Our aim is to surface these small shifts that traditional checklists miss.',
      link: 'Explore the MigraineBrainRadar‚ĄĘ ‚Üí',
    };
---

<BaseLayout title={`${T.title} ‚ÄĒ Migraine Aura Foundation`} lang={locale} active="brain-state">
  <div class="page-head">
    <div class="wrap">
      <Kicker variant="warm">MigraineBrainRadar‚ĄĘ</Kicker>
      <h1 class="page-head__title">{T.title}</h1>
    </div>
  </div>

  <div class="wrap">
    <article class="article mx-auto" style="padding-block: clamp(20px,3vw,36px);">
      <div class="prose">
        <p><strong>{T.lead}</strong></p>
        <p>{T.intro}</p>
      </div>

      <PareidoliaTest lang={isDe ? 'de' : 'en'} ctaHref={mbrHref} />

      <div class="prose" style="margin-top:2rem;">
        <p set:html={T.outro} />
        <p><a href={mbrHref}>{T.link}</a></p>
      </div>
    </article>
  </div>
</BaseLayout>
