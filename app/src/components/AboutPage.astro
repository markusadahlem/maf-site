---
// About page, locale-driven. Shared by /about and /de/about.
import BaseLayout from '../layouts/BaseLayout.astro';
import Kicker from '../components/Kicker.astro';
import SectionHead from '../components/SectionHead.astro';
import TimelineItem from '../components/TimelineItem.astro';
import CtaBand from '../components/CtaBand.astro';
import '../styles/pages.css';

interface Props { locale: string }
const { locale } = Astro.props;
const isDe = locale === 'de';
const p = (path: string) => (isDe ? `/de${path}` : path);

const values = isDe
  ? [
      { n: '01', title: 'Patientenzentriert', text: 'Die individuelle Erfahrung ist unser Ausgangspunkt.' },
      { n: '02', title: 'Wissenschaftsbasiert', text: 'Forschung ist die Grundlage unseres Handelns.' },
      { n: '03', title: 'Translational', text: 'Erkenntnisse direkt in die Versorgung übersetzen.' },
      { n: '04', title: 'Digital kompetent', text: 'Technologie wirksam für Patienten einsetzen.' },
    ]
  : [
      { n: '01', title: 'Patient-centered', text: 'The individual experience is our starting point.' },
      { n: '02', title: 'Science-based', text: 'Research is the foundation of our actions.' },
      { n: '03', title: 'Translational', text: 'Translating insights directly into healthcare.' },
      { n: '04', title: 'Digitally competent', text: 'Using technology effectively for patients.' },
    ];

const founders = [
  { initials: 'MD', name: 'Markus A. Dahlem, PhD', role: isDe ? 'Theoretischer Physiker · Aura-Modellierung & digitale Gesundheit' : 'Theoretical physicist · aura modelling & digital health' },
  { initials: 'KP', name: 'Dr. med. Klaus Podoll', role: isDe ? 'Neurologe · Migränekunst-Archiv (1958–2019)' : 'Neurologist · Migraine Art archive (1958–2019)' },
];

const timeline = isDe
  ? [
      { date: '1998', title: 'Erste Online-Präsenz', text: 'Die erste wissenschaftlich fundierte Simulation der Migräne-Aura — entwickelt während Markus Dahlems Promotion in theoretischer Physik — wird online veröffentlicht und macht die unsichtbare Aura für andere sichtbar.' },
      { date: 'März 2000', title: 'Ermutigung von Oliver Sacks', text: 'Ein persönlicher Brief des Neurologen und Bestsellerautors würdigt die Bedeutung der Arbeit. Sein patientenzentrierter Ansatz wird zu einem Leitprinzip.' },
      { date: '2003', title: 'Die Migränekunst-Plattform wächst', text: 'Eine Zusammenarbeit mit Dr. Klaus Podoll bringt ein umfangreiches Archiv — aufbauend auf Derek Robinsons Pionierarbeit von 1973 — in eine der weltweit bedeutendsten digitalen Sammlungen gelebter Aura-Erfahrungen.' },
      { date: '2004', title: 'Die Stiftung wird gegründet', text: 'Mit einem wachsenden Netzwerk, Gästebuch und der Migränekunst-Sektion wird die Migraine Aura Foundation offiziell gegründet — auf einem dualen Weg aus gemeinnütziger Aufklärung und translationaler Forschung.' },
      { date: '2009', title: 'Ein Buch und ein Blog', text: 'Migraine Art: The Migraine Experience from Within erscheint, und der Wissenschaftsblog Graue Substanz startet — mit schließlich mehr als 400 Beiträgen zur Migränephysiologie.' },
      { date: '2011', title: 'Literarische Anerkennung', text: 'In Die zitternde Frau beschreibt Siri Hustvedt, wie die Aura-Erfahrungen auf der Website der Stiftung neue Perspektiven auf neurologisches Erleben eröffneten.' },
      { date: '2019', title: 'Verlust eines Wegbereiters', text: 'Der Tod von Dr. Klaus Podoll hinterlässt eine große Lücke — ein langjähriger Mitwirkender, der Inhalte, Netzwerk und wissenschaftliche Tiefe der Plattform prägte.' },
      { date: '2025', title: 'Website-Relaunch', text: 'Ein vollständiger Relaunch bringt ein neues Design, die Rückkehr des Blogs und den Aura-o-mat — moderner, interaktiver und integrierter als je zuvor.' },
    ]
  : [
      { date: '1998', title: 'First online presence', text: "The first scientifically grounded simulation of the migraine aura — developed during Markus Dahlem's PhD in theoretical physics — is published online, making the invisible aura visible to others." },
      { date: 'March 2000', title: 'Encouragement from Oliver Sacks', text: "A personal letter from the neurologist and bestselling author acknowledges the work's significance. His patient-centered approach becomes a guiding principle." },
      { date: '2003', title: 'The Migraine Art platform expands', text: "A collaboration with Dr. Klaus Podoll brings an extensive archive — building on Derek Robinson's pioneering work from 1973 — into one of the world's most significant digital collections of lived aura experiences." },
      { date: '2004', title: 'The Foundation is founded', text: 'With a growing network, guestbook, and the Migraine Art section, the Migraine Aura Foundation is officially established — following a dual path of nonprofit education and translational research.' },
      { date: '2009', title: 'A book and a blog', text: 'Migraine Art: The Migraine Experience from Within is published, and the science blog Graue Substanz launches — eventually home to more than 400 posts on migraine physiology.' },
      { date: '2011', title: 'Literary recognition', text: "In The Shaking Woman, Siri Hustvedt describes how the aura experiences on the foundation's website opened new perspectives on neurological experience." },
      { date: '2019', title: 'Loss of a pioneer', text: "The passing of Dr. Klaus Podoll leaves a significant void — a long-time contributor who shaped the platform's content, network, and scientific depth." },
      { date: '2025', title: 'Website relaunch', text: 'A complete relaunch brings a new design, the return of the blog, and the Aura-o-mat — more modern, interactive, and integrated than ever.' },
    ];

const T = isDe
  ? {
      title: 'Über uns', mKicker: 'Unsere Mission', mStatement: 'Migräne <em>sichtbar</em> machen — und klinisch bedeutsam.',
      lead: 'Migräne betrifft fast eine Milliarde Menschen weltweit. Wir stellen die gelebte Erfahrung der Betroffenen in den Mittelpunkt unserer Arbeit — verbinden subjektives Erleben mit objektiver Modellierung und entwickeln digitale Werkzeuge, die Kommunikation, Diagnose und Behandlung verbessern.',
      vKicker: 'Was uns leitet', vTitle: 'Vier Grundwerte',
      fKicker: 'Unsere Gründer', fTitle: 'Wer das begonnen hat',
      hKicker: 'Unsere Geschichte', hTitle: 'Von einer Simulation zur Stiftung', hSub: 'Ein 25-jähriger Bogen, das Unsichtbare sichtbar zu machen — durch Wissenschaft, Kunst und die Patientenstimme.',
      ctaTitle: 'Werde Teil dessen, was kommt', ctaText: 'Vom Leben mit Migräne bis zur Mitgestaltung künftiger Versorgung — teile deine Erfahrung oder arbeite mit uns an Forschung und digitalen Werkzeugen.', ctaLabel: 'Kontakt aufnehmen',
    }
  : {
      title: 'About us', mKicker: 'Our mission', mStatement: 'Making migraine <em>visible</em> — and clinically meaningful.',
      lead: 'Migraine affects nearly one billion people worldwide. We place the lived experience of those affected at the center of our work — connecting subjective experience with objective modelling, and developing digital tools that improve communication, diagnosis, and treatment.',
      vKicker: 'What grounds us', vTitle: 'Four core values',
      fKicker: 'Our founders', fTitle: 'Who started this',
      hKicker: 'Our history', hTitle: 'From a simulation to a foundation', hSub: 'A 25-year arc of making the invisible visible — through science, art, and the patient voice.',
      ctaTitle: 'Be part of what comes next', ctaText: 'From living with migraine to helping shape future care — share your experience, or collaborate with us on research and digital tools.', ctaLabel: 'Get in touch',
    };
---

<BaseLayout title={`${T.title} — Migraine Aura Foundation`} lang={locale}>
  <section class="section">
    <div class="wrap">
      <div class="mission">
        <Kicker variant="blue" center>{T.mKicker}</Kicker>
        <p class="mission__statement" style="margin-top:20px" set:html={T.mStatement} />
      </div>
      <p class="lead center mx-auto" style="max-width:60ch; margin-top:32px;">{T.lead}</p>
    </div>
  </section>

  <section class="section--tight band">
    <div class="wrap">
      <SectionHead kicker={T.vKicker} kickerVariant="warm" title={T.vTitle} />
      <div class="values">
        {values.map((v) => (
          <div class="value"><div class="value__n">{v.n}</div><h3 class="value__title">{v.title}</h3><p class="value__text">{v.text}</p></div>
        ))}
      </div>
    </div>
  </section>

  <section class="section--tight">
    <div class="wrap">
      <SectionHead kicker={T.fKicker} kickerVariant="warm" title={T.fTitle} />
      <div class="founders">
        {founders.map((f) => (
          <div class="founder"><div class="founder__avatar">{f.initials}</div><div><div class="founder__name">{f.name}</div><div class="founder__role">{f.role}</div></div></div>
        ))}
      </div>
    </div>
  </section>

  <section class="section--tight band">
    <div class="wrap">
      <SectionHead kicker={T.hKicker} title={T.hTitle} sub={T.hSub} />
      <div class="timeline">
        {timeline.map((t) => <TimelineItem date={t.date} title={t.title}>{t.text}</TimelineItem>)}
      </div>
    </div>
  </section>

  <section class="section--tight">
    <div class="wrap">
      <CtaBand title={T.ctaTitle} text={T.ctaText} ctaLabel={T.ctaLabel} ctaHref={p('/contact')} />
    </div>
  </section>
</BaseLayout>
