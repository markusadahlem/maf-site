---
// PareidoliaTest — the "Jesus in the toast?" pareidolia perception test, one of
// the MigraineBrainRadar dimensions. Ported from the Hugo pareidolia-test
// shortcode (self-contained HTML+CSS+JS). lang/ctaHref are props read by the
// script from the #mbr dataset; toast images come from /public.
interface Props { lang?: 'en' | 'de'; ctaHref: string }
const { lang = 'en', ctaHref } = Astro.props;
---
<div class="mbr" id="mbr" data-lang={lang} data-cta={ctaHref}>
  <section class="mbr__screen is-active" data-screen="intro">
    <div class="mbr__pad">
      <h2 data-i18n="introTitle"></h2>
      <p data-i18n="introBody"></p>
      <button class="mbr__cta" data-action="start" data-i18n="startBtn"></button>
    </div>
  </section>
  <section class="mbr__screen" data-screen="test">
    <div class="mbr__pad">
      <div class="mbr__stage">
        <img class="mbr__img" alt="" hidden />
        <div class="mbr__fixation" hidden>+</div>
        <div class="mbr__count" hidden></div>
      </div>
      <div class="mbr__progress"><div class="mbr__bar"></div></div>
      <div class="mbr__meta">
        <span data-ref="counter">1 / 10</span>
        <span data-i18n="prompt"></span>
      </div>
      <div class="mbr__btns">
        <button class="mbr__btn mbr__btn--yes" data-answer="yes" disabled>
          <span data-i18n="yes"></span><kbd>J</kbd>
        </button>
        <button class="mbr__btn mbr__btn--no" data-answer="no" disabled>
          <span data-i18n="no"></span><kbd>N</kbd>
        </button>
      </div>
    </div>
  </section>
  <section class="mbr__screen" data-screen="result">
    <div class="mbr__pad">
      <h2 data-i18n="resultTitle"></h2>
      <div class="mbr__score" data-ref="score">0</div>
      <div class="mbr__scorelabel" data-ref="scoreLabel"></div>
      <p data-ref="resultMsg"></p>
      <button class="mbr__cta" data-action="restart" data-i18n="restartBtn"></button>
      <br />
      <a class="mbr__link" data-ref="ctaLink" href="#"></a>
    </div>
  </section>
</div>

<style is:global>
  .mbr {
    --mbr-bg:#faf7f2; --mbr-surface:#ffffff; --mbr-ink:#1d1a17; --mbr-muted:#6f675d;
    --mbr-line:#e7ded2; --mbr-accent:var(--primary, #08768a); --mbr-accent-ink:#ffffff;
    --mbr-yes:#2f7d5b; --mbr-no:#9a3b3b; --mbr-radius:16px;
    --mbr-shadow:0 10px 30px rgba(40,28,12,.10);
    --mbr-font:"Source Serif 4","Iowan Old Style",Georgia,serif;
    --mbr-ui:"Hanken Grotesk",ui-sans-serif,system-ui,sans-serif;
    width:100%; max-width:520px; margin:2rem auto; background:var(--mbr-surface);
    border:1px solid var(--mbr-line); border-radius:var(--mbr-radius);
    box-shadow:var(--mbr-shadow); overflow:hidden; font-family:var(--mbr-ui);
    color:var(--mbr-ink);
  }
  :root[data-theme="dark"] .mbr {
    --mbr-bg:#15120f; --mbr-surface:#1f1b17; --mbr-ink:#f3ece2; --mbr-muted:#a99e90;
    --mbr-line:#352e26; --mbr-shadow:0 10px 30px rgba(0,0,0,.4);
  }
  .mbr__pad { padding:28px 28px 32px; }
  .mbr h2 { font-family:var(--mbr-font); font-weight:600; font-size:1.5rem; line-height:1.2; margin:0 0 .5rem; letter-spacing:-.01em; color:var(--mbr-ink); }
  .mbr p { color:var(--mbr-muted); line-height:1.55; margin:0 0 1rem; }
  .mbr__screen { display:none; }
  .mbr__screen.is-active { display:block; animation:mbrFade .25s ease both; }
  @keyframes mbrFade { from{opacity:0; transform:translateY(4px)} to{opacity:1; transform:none} }
  .mbr__stage { position:relative; aspect-ratio:1/1; width:100%; background:var(--mbr-bg); border-radius:12px; overflow:hidden; display:grid; place-items:center; }
  .mbr__stage.is-blank { background:#fff; }
  .mbr__img { width:100%; height:100%; object-fit:cover; display:block; }
  .mbr__fixation { font-family:var(--mbr-font); font-size:3rem; color:var(--mbr-muted); }
  .mbr__count { font-family:var(--mbr-font); font-size:4.5rem; color:var(--mbr-ink); font-weight:600; }
  .mbr__progress { height:6px; background:var(--mbr-line); border-radius:99px; margin:14px 0 4px; overflow:hidden; }
  .mbr__bar { height:100%; width:100%; background:var(--mbr-accent); border-radius:99px; }
  .mbr__meta { display:flex; justify-content:space-between; font-size:.8rem; color:var(--mbr-muted); margin-bottom:18px; }
  .mbr__btns { display:grid; grid-template-columns:1fr 1fr; gap:12px; }
  .mbr__btn { appearance:none; border:1px solid var(--mbr-line); cursor:pointer; font:inherit; font-weight:600; padding:16px; border-radius:12px; background:var(--mbr-surface); color:var(--mbr-ink); transition:transform .08s ease, background .15s ease, border-color .15s ease, opacity .15s; }
  .mbr__btn:hover { transform:translateY(-1px); }
  .mbr__btn:active { transform:translateY(0); }
  .mbr__btn[disabled] { opacity:.4; cursor:default; transform:none; }
  .mbr__btn--yes.is-picked { background:var(--mbr-yes); border-color:var(--mbr-yes); color:#fff; }
  .mbr__btn--no.is-picked  { background:var(--mbr-no);  border-color:var(--mbr-no);  color:#fff; }
  .mbr__btn kbd { font:inherit; font-size:.7rem; opacity:.6; margin-left:6px; }
  .mbr__cta { display:inline-block; margin-top:8px; padding:15px 22px; border-radius:12px; background:var(--mbr-accent); color:var(--mbr-accent-ink); font:inherit; font-weight:600; border:none; cursor:pointer; transition:transform .08s ease, filter .15s; }
  .mbr__cta:hover { transform:translateY(-1px); filter:brightness(1.05); }
  .mbr__link { display:inline-block; margin-top:14px; color:var(--mbr-accent); text-decoration:none; font-weight:600; }
  .mbr__link:hover { text-decoration:underline; }
  .mbr__score { font-family:var(--mbr-font); font-size:3.4rem; font-weight:600; color:var(--mbr-accent); line-height:1; margin:6px 0 2px; }
  .mbr__scorelabel { color:var(--mbr-muted); margin-bottom:14px; }
  @media (prefers-reduced-motion: reduce) {
    .mbr__bar, .mbr__btn, .mbr__cta { transition:none !important; }
    .mbr__screen.is-active { animation:none; }
  }
</style>

<script>
  const root = document.getElementById('mbr');
  if (root) {
    const CONFIG = {
      lang: root.dataset.lang === 'de' ? 'de' : 'en',
      exposureMs: 4000, isiMs: 600, countInMs: 700, advanceOnAnswer: true,
      ctaHref: root.dataset.cta || '#',
      images: ['a', 'b', 'c', 'd', 'e', 'f', 'g', 'h', 'i', 'j'].map((c, i) => ({
        src: `/images/toast-teaser/carousel/${c}-toast.png`,
        alt: `Toast ${i + 1}`,
      })),
    };
    const STRINGS = {
      de: {
        introTitle: 'Jesus im Toast?',
        introBody: 'Dir werden 10 Toastscheiben kurz nacheinander gezeigt. Entscheide bei jeder spontan: Erkennst du ein Gesicht oder eine Figur – ja oder nein? Am Ende erfährst du dein Ergebnis.',
        startBtn: 'Test starten', prompt: 'Erkennst du eine Figur?', yes: 'Ja', no: 'Nein',
        restartBtn: 'Nochmal', resultTitle: 'Dein Ergebnis',
        scoreLabel: (seen, total) => `von ${total} Toasts mit einer erkannten Figur`,
        interpret: (seen, total) => { const r = seen / total;
          if (r === 0) return 'Du hast in keinem der Bilder eine Figur gesehen – dein Gehirn ist hier sehr „nüchtern" geblieben. Auch das ist völlig normal.';
          if (r < 0.4) return 'Du hast nur in wenigen Bildern etwas erkannt. Pareidolie – das Sehen von Mustern im Zufall – ist bei jedem unterschiedlich ausgeprägt.';
          if (r < 0.8) return 'Dein Gehirn findet in vielen Bildern eine Gestalt. Genau diese Mustererkennung untersucht der MigraineBrainRadar™ genauer.';
          return 'Du siehst fast überall eine Figur – dein Gehirn ist ein ausgeprägter Mustererkenner. Spannend, wie sich das vor, nach und zwischen Migräneattacken verändern kann.'; },
      },
      en: {
        introTitle: 'Jesus in the toast?',
        introBody: "You'll see 10 slices of toast in quick succession. For each one, decide on instinct: do you see a face or figure — yes or no? You'll get your result at the end.",
        startBtn: 'Start the test', prompt: 'See a figure?', yes: 'Yes', no: 'No',
        restartBtn: 'Again', resultTitle: 'Your result',
        scoreLabel: (seen, total) => `out of ${total} toasts where you spotted a figure`,
        interpret: (seen, total) => { const r = seen / total;
          if (r === 0) return "You saw a figure in none of the images — your brain stayed very 'literal' here. That's perfectly normal.";
          if (r < 0.4) return 'You spotted something in only a few images. Pareidolia — seeing patterns in randomness — varies a lot from person to person.';
          if (r < 0.8) return 'Your brain finds a shape in many of the images. This is exactly the kind of pattern-making the MigraineBrainRadar™ looks at more closely.';
          return "You see a figure almost everywhere — your brain is a strong pattern-finder. It's intriguing how this can shift before, after and between migraine attacks."; },
      },
    };
    const T = STRINGS[CONFIG.lang];
    const prefersReduced = matchMedia('(prefers-reduced-motion: reduce)').matches;
    const screens = {};
    root.querySelectorAll('[data-screen]').forEach((s) => (screens[s.dataset.screen] = s));
    const stageEl = root.querySelector('.mbr__stage'), stageImg = root.querySelector('.mbr__img'),
      fixation = root.querySelector('.mbr__fixation'), countEl = root.querySelector('.mbr__count'),
      bar = root.querySelector('.mbr__bar'), counterEl = root.querySelector('[data-ref="counter"]'),
      btnYes = root.querySelector('[data-answer="yes"]'), btnNo = root.querySelector('[data-answer="no"]'),
      scoreEl = root.querySelector('[data-ref="score"]'), scoreLabel = root.querySelector('[data-ref="scoreLabel"]'),
      resultMsg = root.querySelector('[data-ref="resultMsg"]'), ctaLink = root.querySelector('[data-ref="ctaLink"]');
    root.querySelectorAll('[data-i18n]').forEach((el) => { const v = T[el.dataset.i18n]; if (typeof v === 'string') el.textContent = v; });
    ctaLink.textContent = CONFIG.lang === 'de' ? 'Mehr über den MigraineBrainRadar™ →' : 'More about the MigraineBrainRadar™ →';
    ctaLink.href = CONFIG.ctaHref;
    CONFIG.images.forEach((o) => { const im = new Image(); im.src = o.src; });
    const state = { idx: 0, answers: [], pending: undefined, accepting: false, timer: null };
    function showScreen(n) { Object.values(screens).forEach((s) => s.classList.remove('is-active')); screens[n].classList.add('is-active'); }
    function clearTimer() { if (state.timer) { clearTimeout(state.timer); state.timer = null; } }
    function start() {
      if (window.posthog) posthog.capture('pareidolia_started', { lang: CONFIG.lang });
      state.idx = 0; state.answers = []; showScreen('test'); setStageMode('count'); countIn(() => nextImage(), 3);
    }
    function countIn(done, n) { if (CONFIG.countInMs === 0 || n <= 0) { done(); return; } countEl.textContent = n; state.timer = setTimeout(() => countIn(done, n - 1), CONFIG.countInMs); }
    function setStageMode(m) { stageImg.hidden = m !== 'image'; fixation.hidden = m !== 'fixation'; countEl.hidden = m !== 'count'; stageEl.classList.toggle('is-blank', m === 'blank'); }
    function nextImage() {
      if (state.idx >= CONFIG.images.length) { showResult(); return; }
      state.pending = undefined; enableButtons(false); resetButtonStyles();
      if (CONFIG.isiMs > 0) { setStageMode('fixation'); bar.style.transition = 'none'; bar.style.width = '100%'; state.timer = setTimeout(exposeImage, CONFIG.isiMs); }
      else { exposeImage(); }
    }
    function exposeImage() {
      const img = CONFIG.images[state.idx];
      stageImg.src = img.src; stageImg.alt = img.alt; setStageMode('image');
      counterEl.textContent = state.idx + 1 + ' / ' + CONFIG.images.length;
      enableButtons(true); state.accepting = true; runBar(CONFIG.exposureMs); clearTimer();
      state.timer = setTimeout(() => setStageMode('blank'), CONFIG.exposureMs);
    }
    function runBar(ms) { bar.style.transition = 'none'; bar.style.width = '100%'; void bar.offsetWidth; if (prefersReduced) return; bar.style.transition = 'width ' + ms + 'ms linear'; bar.style.width = '0%'; }
    function answer(v) {
      if (!state.accepting) return; state.pending = v;
      btnYes.classList.toggle('is-picked', v === true); btnNo.classList.toggle('is-picked', v === false);
      if (CONFIG.advanceOnAnswer) { clearTimer(); commit(v); }
    }
    function commit(v) { state.accepting = false; enableButtons(false); clearTimer(); state.answers.push(v === true); state.idx++; state.timer = setTimeout(nextImage, 220); }
    function showResult() {
      clearTimer(); const total = CONFIG.images.length; const seen = state.answers.filter(Boolean).length;
      scoreEl.textContent = seen; scoreLabel.textContent = T.scoreLabel(seen, total); resultMsg.textContent = T.interpret(seen, total);
      if (window.posthog) posthog.capture('pareidolia_completed', { lang: CONFIG.lang, score: seen, total });
      showScreen('result');
    }
    function enableButtons(on) { btnYes.disabled = !on; btnNo.disabled = !on; }
    function resetButtonStyles() { btnYes.classList.remove('is-picked'); btnNo.classList.remove('is-picked'); }
    root.querySelector('[data-action="start"]').addEventListener('click', start);
    root.querySelector('[data-action="restart"]').addEventListener('click', start);
    btnYes.addEventListener('click', () => answer(true));
    btnNo.addEventListener('click', () => answer(false));
    document.addEventListener('keydown', (e) => { if (!state.accepting) return; const k = e.key.toLowerCase(); if (k === 'j' || k === 'y') answer(true); if (k === 'n') answer(false); });
  }
</script>
